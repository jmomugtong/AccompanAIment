# Database
DATABASE_URL=postgresql+asyncpg://accompaniment:accompaniment@localhost:5432/accompaniment
DATABASE_URL_SYNC=postgresql://accompaniment:accompaniment@localhost:5432/accompaniment

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama (local LLM server)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_FALLBACK_MODEL=neural-chat

# Storage
STORAGE_PATH=./data/storage
STORAGE_BACKEND=filesystem

# Audio
SOUNDFONT_PATH=./backend/assets/soundfonts/piano.sf2
CREPE_MODEL_CAPACITY=full
MAX_UPLOAD_SIZE_MB=100
MAX_AUDIO_DURATION_SECONDS=600

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Melody cache TTL (seconds) — 7 days
MELODY_CACHE_TTL=604800

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Prometheus
PROMETHEUS_ENABLED=true
